# ── Database ────────────────────────────────────────────────
# Lighthouse uses PostgreSQL in every environment (dev/prod parity).
# Locally, point this at your hosted Postgres connection string — e.g. the
# EXTERNAL connection string of your Render database (Render dashboard →
# your database → "External Database URL"). No local Postgres install needed.
#
# In production on Render this is wired automatically from the database
# resource (see render.yaml) — you do not set it by hand there.
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/lighthouse?sslmode=require"

# ── Queue (automation worker fleet) ─────────────────────────
# Optional. If unset, the API degrades to in-process (no Redis needed);
# set it to run the real Playwright worker fleet via BullMQ.
# REDIS_URL="redis://localhost:6380"

# ── Auth ────────────────────────────────────────────────────
# In production Render generates this for you (render.yaml). Locally, any
# long random string is fine.
JWT_SECRET="change-me-in-prod"

# ── AI (per-directory copy tailoring) ───────────────────────
# Latest models as of 2026: claude-opus-4-8, claude-sonnet-4-6, claude-haiku-4-5-20251001
ANTHROPIC_API_KEY=""
LIGHTHOUSE_COPY_MODEL="claude-opus-4-8"

# ── API ─────────────────────────────────────────────────────
# Hosts inject PORT; locally the API uses API_PORT. WEB_ORIGIN governs CORS
# in dev (the Vite cockpit). In production the API serves the cockpit at the
# same origin, so CORS isn't in play for normal use.
API_PORT="4000"
WEB_ORIGIN="http://localhost:5173"
