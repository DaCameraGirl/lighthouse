# ── Database ────────────────────────────────────────────────
# Local dev uses SQLite (zero install). For production, point this at Postgres
# and change `provider` in apps/api/prisma/schema.prisma to "postgresql".
DATABASE_URL="file:./dev.db"

# ── Queue (automation worker fleet) ─────────────────────────
# Optional locally. If unset, the API degrades to in-process (no Redis needed);
# set it to run the real Playwright worker fleet via BullMQ.
# REDIS_URL="redis://localhost:6380"

# ── Auth ────────────────────────────────────────────────────
JWT_SECRET="change-me-in-prod"

# ── AI (per-directory copy tailoring) ───────────────────────
# Latest models as of 2026: claude-opus-4-8, claude-sonnet-4-6, claude-haiku-4-5-20251001
ANTHROPIC_API_KEY=""
LIGHTHOUSE_COPY_MODEL="claude-opus-4-8"

# ── API ─────────────────────────────────────────────────────
API_PORT="4000"
WEB_ORIGIN="http://localhost:5173"
