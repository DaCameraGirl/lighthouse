{
  "name": "lighthouse",
  "version": "0.1.0",
  "private": true,
  "description": "Lighthouse — enterprise startup directory submission & distribution platform",
  "license": "Apache-2.0",
  "author": "Angela Hudson (DaCameraGirl)",
  "type": "module",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "npm run dev --workspaces --if-present",
    "build": "npm run build --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "test": "vitest run",
    "db:up": "docker compose up -d db",
    "db:migrate": "npm run db:migrate --workspace apps/api"
  },
  "devDependencies": {
    "vitest": "^2.0.5"
  }
}
